    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.4.21",
    "eslint": "9.22.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "jsdom": "26.1.0",
    "postcss": "8.5.6",
    "prettier": "3.5.3",
